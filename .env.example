# Gemini API key used by the pipeline (Phase A/B/C research + audit).
# Kept separate from the council key so per-cycle pipeline cost is isolated.
GEMINI_API_KEY=

# Optional: distinct key for the council workflow. If unset, council falls back
# to GEMINI_API_KEY. GitHub Actions secret `GEMINI_API_KEY_COUNCIL` is preferred
# for billing isolation between pipeline runs and PR reviews.
# GEMINI_API_KEY_COUNCIL=

# Firebase Admin SDK auth. Either GOOGLE_APPLICATION_CREDENTIALS pointing at a
# service-account JSON, or FIREBASE_SERVICE_ACCOUNT_KEY as the inline JSON.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_KEY=

# Firestore project + named database.
GOOGLE_CLOUD_PROJECT=urban-explorer-483600
FIRESTORE_DATABASE=travel-cities

# User-Agent sent by scrapers. Required by Wikipedia / Reddit etiquette.
PIPELINE_USER_AGENT=city-atlas-service/1.0 (+https://github.com/Anguijm/city-atlas-service)

# Optional: increase per-subprocess timeout (seconds) for long Gemini calls.
PIPELINE_SUBPROCESS_TIMEOUT=3600
